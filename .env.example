APP_ENV=local
DATABASE_URL=sqlite:///./complaints.db
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# LLM options:
# - disabled: never call the LLM, use trained model or deterministic fallback
# - ollama: call a local Ollama server, for example llama3.2
# - openai_compatible: call any /chat/completions-compatible endpoint
LLM_PROVIDER=ollma
LLM_API_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_MODEL=llama3.2
LLM_TIMEOUT_SECONDS=90
USE_LLM_CLASSIFIER=true

MODEL_PATH=models/complaint_classifier.joblib
SLA_POLL_SECONDS=15
DASHBOARD_API_URL=http://localhost:8000
